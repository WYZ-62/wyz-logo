---
import { PageHeader } from "@components/features/page-header";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getTagList } from "@utils/content-utils";
import { getTagUrl } from "@utils/url-utils";

const tags = await getTagList();
const title = "标签";
const subtitle = `共 ${tags.length} 个标签，点击后可查看对应文章列表。`;
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-6 sm:px-9 py-6 relative w-full">
			<PageHeader title={title} subtitle={subtitle} />

			{
				tags.length > 0 ? (
					<div class="tags-grid">
						{tags.map((tag) => (
							<a
								href={getTagUrl(tag.name)}
								class="tag-card group"
								aria-label={`查看 ${tag.name} 标签下的全部文章`}
							>
								<div class="tag-card__content">
									<h2 class="tag-card__title">{tag.name}</h2>
									<p class="tag-card__count">
										{tag.count} 篇文章
									</p>
								</div>
								<div class="tag-card__badge" aria-hidden="true">
									#
								</div>
							</a>
						))}
					</div>
				) : (
					<p class="text-black/50 dark:text-white/50">
						当前还没有可展示的标签。
					</p>
				)
			}
		</div>
	</div>
</MainGridLayout>

<style>
	.tags-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 1rem;
	}

	.tag-card {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 8rem;
		padding: 1.5rem 1.7rem;
		border-radius: 1.75rem;
		background: color-mix(in srgb, var(--card-bg) 97%, white 3%);
		border: 1px solid
			color-mix(in srgb, var(--line-divider) 80%, transparent);
		box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
		text-decoration: none;
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease,
			border-color 0.25s ease;
	}

	.tag-card:hover {
		transform: translateY(-4px);
		border-color: color-mix(
			in srgb,
			var(--primary) 28%,
			var(--line-divider)
		);
		box-shadow: 0 20px 38px rgba(15, 23, 42, 0.08);
	}

	.tag-card__content {
		display: flex;
		flex: 1;
		flex-direction: column;
		justify-content: center;
		min-width: 0;
	}

	.tag-card__title {
		margin: 0;
		color: rgba(15, 23, 42, 0.92);
		font-size: clamp(1.65rem, 2vw, 2rem);
		font-weight: 800;
		line-height: 1.15;
		word-break: break-word;
	}

	.tag-card__count {
		margin: 0.9rem 0 0;
		color: rgba(15, 23, 42, 0.45);
		font-size: 1rem;
		font-weight: 600;
	}

	.tag-card__badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3.65rem;
		height: 3.65rem;
		border-radius: 1.25rem;
		background: var(--btn-regular-bg);
		color: var(--btn-content);
		font-size: 2rem;
		font-weight: 800;
		flex-shrink: 0;
		transition:
			transform 0.25s ease,
			background-color 0.25s ease,
			color 0.25s ease;
	}

	.tag-card:hover .tag-card__badge {
		transform: scale(1.04);
	}

	:global(.dark) .tag-card {
		background: color-mix(in srgb, var(--card-bg) 94%, black 6%);
		box-shadow: 0 14px 30px rgba(0, 0, 0, 0.2);
	}

	:global(.dark) .tag-card__title {
		color: rgba(255, 255, 255, 0.92);
	}

	:global(.dark) .tag-card__count {
		color: rgba(255, 255, 255, 0.5);
	}

	@media (min-width: 768px) {
		.tags-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.25rem;
		}
	}

	@media (max-width: 640px) {
		.tag-card {
			min-height: 7rem;
			padding: 1.25rem;
			border-radius: 1.4rem;
		}

		.tag-card__title {
			font-size: 1.45rem;
		}

		.tag-card__count {
			margin-top: 0.75rem;
			font-size: 0.95rem;
		}

		.tag-card__badge {
			width: 3rem;
			height: 3rem;
			border-radius: 1rem;
			font-size: 1.65rem;
		}
	}
</style>
