---
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getSortedPostsList } from "@/utils/content-utils";
import { pathsEqual } from "@/utils/url-utils";

import WidgetLayout from "../common/WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;
const currentPath = Astro.url.pathname;
const allPosts = await getSortedPostsList();

const visiblePosts = allPosts
	.filter((post) => !post.data.password && post.url)
	.map((post, index) => ({
		...post,
		order: index + 1,
		category:
			typeof post.data.category === "string" &&
			post.data.category.trim().length > 0
				? post.data.category.trim()
				: i18n(I18nKey.uncategorized),
		isActive: post.url ? pathsEqual(currentPath, post.url) : false,
	}));
---

<WidgetLayout
	name="目录"
	id="card-toc"
	class={"group " + (className || "")}
	style={style}
>
	<div class="doc-list">
		{
			visiblePosts.length > 0 ? (
				visiblePosts.map((post) => (
					<a
						href={post.url}
						class:list={[
							"doc-item",
							{ active: post.isActive },
						]}
						aria-current={post.isActive ? "page" : undefined}
					>
						<span class="doc-index">{post.order}</span>
						<span class="doc-copy">
							<span class="doc-title">{post.data.title}</span>
							<span class="doc-meta">{post.category}</span>
						</span>
					</a>
				))
			) : (
				<div class="doc-empty">暂时还没有可展示的文档</div>
			)
		}
	</div>
</WidgetLayout>

<style>
	.doc-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 0.1rem 0 0.25rem;
		max-height: 34.5rem;
		overflow-y: auto;
		scrollbar-width: thin;
		scrollbar-color: transparent transparent;
	}

	.doc-list::-webkit-scrollbar {
		width: 0.2rem;
	}

	.doc-list::-webkit-scrollbar-track {
		background: transparent;
	}

	.doc-list::-webkit-scrollbar-thumb {
		border-radius: 999px;
		background: transparent;
		transition: background 0.2s ease;
	}

	.doc-list:hover {
		scrollbar-color: color-mix(in oklab, var(--primary) 16%, transparent)
			transparent;
	}

	.doc-list:hover::-webkit-scrollbar-thumb {
		background: color-mix(in oklab, var(--primary) 16%, transparent);
	}

	.doc-list:active {
		scrollbar-color: color-mix(in oklab, var(--primary) 22%, transparent)
			transparent;
	}

	.doc-list:active::-webkit-scrollbar-thumb {
		background: color-mix(in oklab, var(--primary) 22%, transparent);
	}

	.doc-item {
		display: grid;
		grid-template-columns: 2.1rem minmax(0, 1fr);
		align-items: flex-start;
		gap: 0.8rem;
		padding: 0.82rem 0.86rem;
		border-radius: 1rem;
		text-decoration: none;
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--card-bg) 92%, var(--primary) 8%) 0%,
				color-mix(in oklab, var(--card-bg) 98%, white 2%) 100%
			);
		border: 1px solid
			color-mix(in oklab, var(--primary) 14%, var(--line-divider));
		box-shadow: 0 12px 24px -24px
			color-mix(in oklab, var(--primary) 32%, transparent);
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.doc-item:hover {
		transform: translateY(-2px);
		border-color: color-mix(in oklab, var(--primary) 36%, var(--line-divider));
		box-shadow: 0 16px 32px -24px
			color-mix(in oklab, var(--primary) 42%, transparent);
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--card-bg) 88%, var(--primary) 12%) 0%,
				color-mix(in oklab, var(--card-bg) 94%, var(--primary) 6%) 100%
			);
	}

	.doc-item.active {
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--card-bg) 78%, var(--primary) 22%) 0%,
				color-mix(in oklab, var(--card-bg) 88%, var(--primary) 12%) 100%
			);
		border-color: color-mix(in oklab, var(--primary) 46%, var(--line-divider));
		box-shadow: 0 18px 36px -26px
			color-mix(in oklab, var(--primary) 46%, transparent);
	}

	.doc-index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		border-radius: 0.85rem;
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, white 68%, var(--primary) 32%) 0%,
				color-mix(in oklab, white 52%, var(--primary) 48%) 100%
			);
		color: color-mix(in oklab, var(--primary) 72%, black);
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
		flex-shrink: 0;
	}

	.doc-item.active .doc-index {
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, white 56%, var(--primary) 44%) 0%,
				color-mix(in oklab, white 36%, var(--primary) 64%) 100%
			);
		color: color-mix(in oklab, var(--primary) 58%, black);
	}

	.doc-copy {
		display: flex;
		flex-direction: column;
		gap: 0.36rem;
		min-width: 0;
	}

	.doc-title {
		color: color-mix(in oklab, var(--deep-text) 92%, black 8%);
		font-size: 0.96rem;
		font-weight: 700;
		line-height: 1.45;
		word-break: break-word;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.doc-meta {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		max-width: 100%;
		padding: 0.18rem 0.58rem;
		border-radius: 999px;
		background: color-mix(in oklab, var(--primary) 12%, transparent);
		color: color-mix(in oklab, var(--primary) 78%, black);
		font-size: 0.72rem;
		font-weight: 600;
		line-height: 1.3;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.doc-empty {
		padding: 0.85rem 0.25rem 0.5rem;
		color: var(--content-meta);
		font-size: 0.9rem;
		line-height: 1.6;
	}

	:global(.dark) .doc-item {
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--card-bg) 90%, var(--primary) 10%) 0%,
				color-mix(in oklab, var(--card-bg) 96%, black 4%) 100%
			);
		border-color: color-mix(in oklab, var(--primary) 18%, var(--line-divider));
		box-shadow: 0 16px 34px -28px rgba(0, 0, 0, 0.72);
	}

	:global(.dark) .doc-item:hover {
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--card-bg) 84%, var(--primary) 16%) 0%,
				color-mix(in oklab, var(--card-bg) 92%, var(--primary) 8%) 100%
			);
		border-color: color-mix(in oklab, var(--primary) 28%, var(--line-divider));
	}

	:global(.dark) .doc-item.active {
		background:
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--card-bg) 76%, var(--primary) 24%) 0%,
				color-mix(in oklab, var(--card-bg) 86%, var(--primary) 14%) 100%
			);
		border-color: color-mix(in oklab, var(--primary) 34%, var(--line-divider));
	}

	:global(.dark) .doc-title {
		color: color-mix(in oklab, white 92%, var(--primary) 8%);
	}

	:global(.dark) .doc-meta {
		background: color-mix(in oklab, var(--primary) 16%, transparent);
		color: color-mix(in oklab, white 72%, var(--primary) 28%);
	}

	:global(.dark) .doc-empty {
		color: var(--content-meta);
	}
</style>
