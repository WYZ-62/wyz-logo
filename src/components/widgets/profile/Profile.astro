---
import { Icon } from "astro-icon/components";
import { profileConfig, siteConfig } from "../../../config";
import TypewriterText from "../../atoms/typewriter-text/TypewriterText.astro";
import { url } from "../../../utils/url-utils";
import Image from "../../atoms/Image/Image.astro";

const umamiDashboardUrl =
	siteConfig.thirdPartyAnalytics?.umami?.dashboardUrl || "";
---

<div class="card-base p-3">
	<a
		aria-label="Go to About Page"
		href={url("/about/")}
		class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95"
	>
		<div
			class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center"
		>
			<Icon
				name="fa7-regular:address-card"
				class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl"
			/>
		</div>
		<Image
			src={profileConfig.avatar || ""}
			alt="Profile Image of the Author"
			class="mx-auto lg:w-full h-full lg:mt-0"
			loading="eager"
			fetchpriority="high"
		/>
	</a>
	<div class="px-2">
		<div
			class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition"
		>
			{profileConfig.name}
		</div>
		<div
			class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"
		>
		</div>

		<div class="text-center text-neutral-400 mb-2.5 transition">
			{
				profileConfig.typewriter?.enable ? (
					<TypewriterText
						text={profileConfig.bio || ""}
						speed={profileConfig.typewriter.speed}
						class="inline-block"
					/>
				) : (
					profileConfig.bio
				)
			}
		</div>

		<div class="flex flex-wrap gap-2 justify-center mb-1">
			{
				profileConfig.links.length > 1 &&
					profileConfig.links.map((item) => (
						<a
							rel="me"
							aria-label={item.name}
							href={item.url}
							target="_blank"
							class="btn-regular rounded-lg h-10 w-10 active:scale-90"
						>
							<Icon name={item.icon} class="text-[1.5rem]" />
						</a>
					))
			}
			{
				profileConfig.links.length == 1 && (
					<a
						rel="me"
						aria-label={profileConfig.links[0].name}
						href={profileConfig.links[0].url}
						target="_blank"
						class="btn-regular rounded-lg h-10 gap-2 px-3 font-bold active:scale-95"
					>
						<Icon
							name={profileConfig.links[0].icon}
							class="text-[1.5rem]"
						/>
						{profileConfig.links[0].name}
					</a>
				)
			}
		</div>

		{
			umamiDashboardUrl && (
				<a
					href={umamiDashboardUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="stats-dashboard-link group"
					aria-label="查看站点统计后台"
				>
					<div class="stats-dashboard-link__icon">
						<Icon name="material-symbols:query-stats" />
					</div>
					<div class="stats-dashboard-link__body">
						<div class="stats-dashboard-link__title">数据统计</div>
						<div class="stats-dashboard-link__desc">
							查看 Umami 站点访问数据
						</div>
					</div>
					<div class="stats-dashboard-link__arrow">
						<Icon name="fa7-solid:arrow-up-right-from-square" />
					</div>
				</a>
			)
		}
	</div>
</div>

<style>
	.stats-dashboard-link {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		width: 100%;
		margin-top: 0.7rem;
		padding: 0.85rem 0.95rem;
		border-radius: 1rem;
		text-decoration: none;
		background: color-mix(in srgb, var(--btn-regular-bg) 72%, white 28%);
		border: 1px solid color-mix(in srgb, var(--primary) 12%, transparent);
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.stats-dashboard-link:hover {
		transform: translateY(-2px);
		border-color: color-mix(in srgb, var(--primary) 28%, transparent);
		box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
	}

	.stats-dashboard-link__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.6rem;
		height: 2.6rem;
		border-radius: 0.95rem;
		flex-shrink: 0;
		background: color-mix(in srgb, var(--primary) 12%, white);
		color: var(--btn-content);
		font-size: 1.35rem;
	}

	.stats-dashboard-link__body {
		flex: 1;
		min-width: 0;
		text-align: left;
	}

	.stats-dashboard-link__title {
		font-size: 0.98rem;
		font-weight: 700;
		color: rgba(15, 23, 42, 0.84);
	}

	.stats-dashboard-link__desc {
		margin-top: 0.18rem;
		font-size: 0.8rem;
		color: rgba(15, 23, 42, 0.48);
	}

	.stats-dashboard-link__arrow {
		flex-shrink: 0;
		font-size: 0.82rem;
		color: rgba(15, 23, 42, 0.3);
		transition: color 0.2s ease;
	}

	.stats-dashboard-link:hover .stats-dashboard-link__arrow {
		color: var(--btn-content);
	}

	:global(.dark) .stats-dashboard-link {
		background: color-mix(in srgb, var(--btn-regular-bg) 48%, black 52%);
	}

	:global(.dark) .stats-dashboard-link__title {
		color: rgba(255, 255, 255, 0.86);
	}

	:global(.dark) .stats-dashboard-link__desc {
		color: rgba(255, 255, 255, 0.48);
	}

	:global(.dark) .stats-dashboard-link__arrow {
		color: rgba(255, 255, 255, 0.3);
	}
</style>
