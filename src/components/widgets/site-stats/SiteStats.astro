---
import { Icon } from "astro-icon/components";

import { siteConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import {
	getSortedPostsList,
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "../../../utils/content-utils";
import { buildTopics } from "../../../data/topics";
import { getPostUrl, getTopicUrl } from "../../../utils/url-utils";
import WidgetLayout from "../common/WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// 从配置中获取站点开始日期
const siteStartDate = siteConfig.siteStartDate || "2025-01-01";
const umamiShareUrl = Boolean(siteConfig.thirdPartyAnalytics?.umami?.shareUrl);

// 获取所有文章
const posts = await getSortedPosts();
const topics = buildTopics(await getSortedPostsList());
const contentPaths = [
	...posts.map((post) => getPostUrl(post)),
	...topics.map((topic) => getTopicUrl(topic.id)),
];
const categories = await getCategoryList();
const tags = await getTagList();

// 计算总字数
let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		let text = post.body;

		// 移除代码块
		text = text.replace(/```[\s\S]*?```/g, "");
		// 移除 ` 包裹的行内代码
		text = text.replace(/`[^`]+`/g, "");

		// 使用与 remark-content.mjs 完全一致的 CJK 正则
		const cjkPattern =
			/[\u4e00-\u9fa5\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af\u3000-\u303f\uff00-\uffef]/g;

		const cjkMatches = text.match(cjkPattern);
		const cjkCount = cjkMatches ? cjkMatches.length : 0;

		// 计算非 CJK 单词数
		const nonCjkText = text.replace(cjkPattern, " ");

		// 按空白字符分割，计算单词数量
		const nonCjkWords = nonCjkText
			.split(/\s+/)
			.filter((word) => word.trim().length > 0);

		totalWords += cjkCount + nonCjkWords.length;
	}
}

// 格式化数字（添加千位分隔符）
function formatNumber(num: number): string {
	return num.toLocaleString();
}

// 获取最新文章日期（忽略置顶状态，只按发布日期排序）
const latestPost = posts.reduce((latest, post) => {
	if (!latest) {
		return post;
	}
	return post.data.published > latest.data.published ? post : latest;
}, posts[0]);

const lastPostDate = latestPost
	? latestPost.data.published.toISOString()
	: null;

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length,
	},
	{
		icon: "material-symbols:folder-outline",
		label: i18n(I18nKey.siteStatsCategoryCount),
		value: categories.length,
	},
	{
		icon: "material-symbols:label-outline",
		label: i18n(I18nKey.siteStatsTagCount),
		value: tags.length,
	},
	{
		icon: "material-symbols:text-ad-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalWords),
		value: totalWords,
		formatted: true,
	},
	{
		icon: "material-symbols:local-library-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalViews),
		value: "—",
		dynamic: true,
		id: "total-views",
		hidden: !umamiShareUrl,
	},
	{
		icon: "material-symbols:calendar-clock-outline",
		label: i18n(I18nKey.siteStatsRunningDays),
		value: 0, // 将由客户端更新
		suffix: i18n(I18nKey.siteStatsDays).replace("{days}", ""),
		dynamic: true,
		id: "running-days",
	},
	{
		icon: "material-symbols:ecg-heart-outline",
		label: i18n(I18nKey.siteStatsLastUpdate),
		value: 0, // 将由客户端更新
		suffix: i18n(I18nKey.siteStatsDaysAgo).replace("{days}", ""),
		dynamic: true,
		id: "last-update",
	},
];
---

<WidgetLayout
	name={i18n(I18nKey.siteStats)}
	id="site-stats"
	class={className}
	style={style}
>
	<div class="flex flex-col gap-1">
		{
			stats
				.filter((stat) => !stat.hidden)
				.map((stat) => (
					<div class="flex items-center justify-between px-2 py-2">
						<div class="flex items-center gap-2.5 flex-1 min-w-0">
							<div class="text-[var(--primary)] text-xl shrink-0">
								<Icon name={stat.icon} />
							</div>
							<span class="text-neutral-700 dark:text-neutral-300 font-medium text-sm break-words leading-tight">
								{stat.label}
							</span>
						</div>
						<div class="flex items-center ml-3 shrink-0">
							<span
								class="text-base font-bold text-neutral-900 dark:text-neutral-100"
								data-stat-id={stat.id}
							>
								{stat.formatted
									? formatNumber(stat.value)
									: stat.value}
							</span>
							{stat.suffix && (
								<span class="text-sm text-neutral-500 dark:text-neutral-400 ml-1">
									{stat.suffix}
								</span>
							)}
						</div>
					</div>
				))
		}
	</div>
</WidgetLayout>

<script
	is:inline
	define:vars={{
		siteStartDate,
		lastPostDate,
		umamiShareUrl: Boolean(umamiShareUrl),
		contentPaths,
	}}
>
	(function () {
	const TOTAL_VIEWS_CACHE_KEY = "mizuki-content-total-views-v1";
	const TOTAL_VIEWS_CACHE_TTL = 10 * 60 * 1000;
	const FETCH_CONCURRENCY = 4;
	function normalizePath(pathname) {
		let normalized = pathname || "/";

		try {
			normalized = new URL(normalized, window.location.origin).pathname;
		} catch {}

		if (normalized !== "/") {
			normalized = `${normalized.replace(/\/+$/, "")}/`;
		}

		return normalized || "/";
	}

	const normalizedContentPaths = contentPaths.map((path) =>
		normalizePath(path),
	);
	const uniqueContentPaths = Array.from(new Set(normalizedContentPaths));
	let updateRequestId = 0;
	let retryTimer = null;

	function updateDynamicStats() {
		const today = new Date();

		// 更新运行天数
		const startDate = new Date(siteStartDate);
		const diffTime = Math.abs(today.getTime() - startDate.getTime());
		const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

		const runningDaysElements = document.querySelectorAll(
			'[data-stat-id="running-days"]',
		);
		if (runningDaysElements.length > 0) {
			runningDaysElements.forEach((element) => {
				element.textContent = diffDays.toString();
			});
		}

		// 更新最后活动时间
		if (lastPostDate) {
			const lastPost = new Date(lastPostDate);
			const timeSinceLastPost = Math.abs(
				today.getTime() - lastPost.getTime(),
			);
			const daysSinceLastUpdate = Math.floor(
				timeSinceLastPost / (1000 * 60 * 60 * 24),
			);

			const lastUpdateElements = document.querySelectorAll(
				'[data-stat-id="last-update"]',
			);
			if (lastUpdateElements.length > 0) {
				lastUpdateElements.forEach((element) => {
					element.textContent = daysSinceLastUpdate.toString();
				});
			}
		}
	}

	function renderTotalViews(totalViews) {
		const totalViewsElements = document.querySelectorAll(
			'[data-stat-id="total-views"]',
		);

		totalViewsElements.forEach((element) => {
			element.textContent = totalViews.toLocaleString();
		});
	}

	function readDisplayedTotalViews() {
		const element = document.querySelector('[data-stat-id="total-views"]');
		if (!element) {
			return null;
		}

		const currentValue = Number.parseInt(
			(element.textContent || "0").replace(/,/g, ""),
			10,
		);

		return Number.isFinite(currentValue) ? currentValue : null;
	}

	function readCachedTotalViews() {
		try {
			const raw = localStorage.getItem(TOTAL_VIEWS_CACHE_KEY);
			if (!raw) {
				return null;
			}

			const parsed = JSON.parse(raw);
			if (
				typeof parsed?.value === "number" &&
				typeof parsed?.timestamp === "number" &&
				Date.now() - parsed.timestamp < TOTAL_VIEWS_CACHE_TTL
			) {
				return parsed.value;
			}
		} catch {}

		return null;
	}

	function writeCachedTotalViews(totalViews) {
		try {
			localStorage.setItem(
				TOTAL_VIEWS_CACHE_KEY,
				JSON.stringify({
					value: totalViews,
					timestamp: Date.now(),
				}),
			);
		} catch {}
	}

	function scheduleRetry(options, delayMs = 2000) {
		if (retryTimer) {
			window.clearTimeout(retryTimer);
		}

		retryTimer = window.setTimeout(() => {
			updateUmamiStats(options);
		}, delayMs);
	}

	async function fetchContentStats(options) {
		const results = new Array(uniqueContentPaths.length);
		let cursor = 0;

		async function worker() {
			while (cursor < uniqueContentPaths.length) {
				const currentIndex = cursor++;
				const path = uniqueContentPaths[currentIndex];
				try {
					results[currentIndex] = await window.oddmisc.getPageStats(
						path,
						options || {},
					);
				} catch (error) {
					results[currentIndex] = { error };
				}
			}
		}

		const workers = Array.from(
			{ length: Math.min(FETCH_CONCURRENCY, uniqueContentPaths.length) },
			() => worker(),
		);
		await Promise.all(workers);
		return results;
	}

	async function updateUmamiStats(options) {
		if (!umamiShareUrl) {
			return;
		}

		const totalViewsElements = document.querySelectorAll(
			'[data-stat-id="total-views"]',
		);
		if (totalViewsElements.length === 0) {
			return;
		}

		if (!window.oddmisc?.getPageStats) {
			scheduleRetry(options, 600);
			return;
		}

		const requestId = ++updateRequestId;

		try {
			const contentStats = await fetchContentStats(options);
			if (requestId !== updateRequestId) {
				return;
			}

			const failedCount = contentStats.filter((stat) => stat?.error).length;
			if (failedCount > 0) {
				if (readDisplayedTotalViews() === null) {
					const cachedTotal = readCachedTotalViews();
					if (cachedTotal !== null) {
						renderTotalViews(cachedTotal);
					}
				}
				scheduleRetry({ force: true }, 3000);
				return;
			}

			const totalViews = contentStats.reduce(
				(sum, stat) => sum + (stat?.pageviews || 0),
				0,
			);
			renderTotalViews(totalViews);
			writeCachedTotalViews(totalViews);
		} catch (error) {
			console.error("Error fetching site stats:", error);
			if (readDisplayedTotalViews() === null) {
				const cachedTotal = readCachedTotalViews();
				if (cachedTotal !== null) {
					renderTotalViews(cachedTotal);
				}
			}
			scheduleRetry({ force: true }, 3000);
		}
	}

	// 页面加载时更新
	updateDynamicStats();
	const cachedTotalViews = readCachedTotalViews();
	if (cachedTotalViews !== null) {
		renderTotalViews(cachedTotalViews);
	}
	updateUmamiStats();
	if (!window.__siteStatsUmamiInitialized) {
		window.__siteStatsUmamiInitialized = true;
		window.addEventListener("oddmisc-ready", () => updateUmamiStats());
		window.addEventListener("umami:stats-refresh", () =>
			updateUmamiStats({ force: true }),
		);
	}

	// 每小时更新一次（可选，因为天数变化较慢）
	setInterval(updateDynamicStats, 60 * 60 * 1000);
	setInterval(updateUmamiStats, 10 * 60 * 1000);
	})();
</script>
