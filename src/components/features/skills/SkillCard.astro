---
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import Icon from "../../misc/Icon.astro";
import type { SkillCardProps } from "./types";

const { skill } = Astro.props as SkillCardProps;

const skillColor = skill.color || "#3B82F6";

const getLevelText = (level: string) => {
	switch (level) {
		case "expert":
			return i18n(I18nKey.skillsExpert);
		case "advanced":
			return i18n(I18nKey.skillsAdvanced);
		case "intermediate":
			return i18n(I18nKey.skillsIntermediate);
		case "beginner":
			return i18n(I18nKey.skillsBeginner);
		default:
			return level;
	}
};

const getLevelWidth = (level: string) => {
	switch (level) {
		case "expert":
			return "100%";
		case "advanced":
			return "82%";
		case "intermediate":
			return "60%";
		case "beginner":
			return "38%";
		default:
			return "50%";
	}
};

const formatExperience = (exp: { years: number; months: number }) => {
	const parts: string[] = [];
	if (exp.years > 0) {
		parts.push(`${exp.years} ${i18n(I18nKey.skillYears)}`);
	}
	if (exp.months > 0) {
		parts.push(`${exp.months} ${i18n(I18nKey.skillMonths)}`);
	}
	return parts.join(" ");
};
---

<article
	class="skill-card group"
	data-category={skill.category}
	style={`--skill-color: ${skillColor};`}
>
	<div class="skill-card-inner">
		<div class="skill-card-head">
			<div class="skill-title-group">
				<span class="skill-icon-box">
					<Icon
						icon={skill.icon}
						class="text-[1.45rem]"
						color={skillColor}
						fallback={skill.name.charAt(0)}
						loading="eager"
					/>
				</span>
				<div class="skill-title-copy">
					<h3>{skill.name}</h3>
					<p>{formatExperience(skill.experience)}</p>
				</div>
			</div>
			<span class="skill-level-badge">{getLevelText(skill.level)}</span>
		</div>

		<p class="skill-description">
			<span class="skill-description-bullet" aria-hidden="true"></span>
			{skill.description}
		</p>

		<div class="skill-progress-track" aria-hidden="true">
			<div
				class="skill-progress-fill"
				style={`width: ${getLevelWidth(skill.level)}`}
			></div>
		</div>
	</div>
</article>

<style>
	.skill-card {
		position: relative;
		min-height: 13.6rem;
		border-radius: 1.65rem;
		border: 1px solid color-mix(in srgb, var(--skill-color) 18%, rgba(148, 163, 184, 0.24));
		background:
			radial-gradient(circle at 14% 12%, color-mix(in srgb, var(--skill-color) 10%, white) 0, transparent 24%),
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--skill-color) 8%, rgba(255, 255, 255, 0.98)),
				rgba(255, 255, 255, 0.94) 58%,
				color-mix(in srgb, var(--skill-color) 4%, rgba(255, 248, 245, 0.92))
			);
		box-shadow:
			0 14px 34px rgba(15, 23, 42, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.9);
		overflow: hidden;
		animation: fadeInUp 0.45s ease-out both;
		transition:
			transform 0.26s ease,
			box-shadow 0.26s ease,
			border-color 0.26s ease;
	}

	.skill-card::before,
	.skill-card::after {
		position: absolute;
		content: "";
		pointer-events: none;
	}

	.skill-card::before {
		inset: 0;
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.3), transparent 32%),
			radial-gradient(circle at 82% 18%, color-mix(in srgb, var(--skill-color) 8%, transparent) 0, transparent 42%);
		opacity: 0.9;
	}

	.skill-card::after {
		right: 1rem;
		bottom: 1rem;
		width: 1.4rem;
		height: 0.76rem;
		border-radius: 999px 999px 999px 0;
		background: rgba(255, 211, 226, 0.52);
		transform: rotate(-28deg);
		filter: blur(0.4px);
		opacity: 0.75;
	}

	.skill-card:hover {
		transform: translateY(-4px);
		border-color: color-mix(in srgb, var(--skill-color) 28%, rgba(148, 163, 184, 0.24));
		box-shadow:
			0 20px 44px rgba(15, 23, 42, 0.1),
			0 0 0 1px color-mix(in srgb, var(--skill-color) 8%, transparent);
	}

	.dark .skill-card {
		border-color: color-mix(in srgb, var(--skill-color) 22%, rgba(255, 255, 255, 0.08));
		background:
			radial-gradient(circle at 14% 12%, color-mix(in srgb, var(--skill-color) 16%, rgba(255, 255, 255, 0.06)) 0, transparent 24%),
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--skill-color) 12%, rgba(15, 23, 42, 0.96)),
				rgba(15, 23, 42, 0.88) 62%,
				color-mix(in srgb, var(--skill-color) 7%, rgba(15, 23, 42, 0.9))
			);
		box-shadow:
			0 18px 38px rgba(0, 0, 0, 0.22),
			inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}

	.dark .skill-card::after {
		background: rgba(244, 114, 182, 0.22);
	}

	.skill-card.filtered-out {
		display: none;
	}

	.skill-card-inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: 1.45rem 1.5rem 1.3rem;
	}

	.skill-card-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.skill-title-group {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		min-width: 0;
	}

	.skill-icon-box {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 4.2rem;
		height: 4.2rem;
		flex: 0 0 auto;
		border-radius: 1.25rem;
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--skill-color) 10%, white),
				color-mix(in srgb, var(--skill-color) 16%, white)
			);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.92),
			0 8px 20px color-mix(in srgb, var(--skill-color) 10%, transparent);
	}

	.dark .skill-icon-box {
		background:
			linear-gradient(
				180deg,
				color-mix(in srgb, var(--skill-color) 16%, rgba(255, 255, 255, 0.08)),
				color-mix(in srgb, var(--skill-color) 22%, rgba(255, 255, 255, 0.04))
			);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.06),
			0 8px 20px rgba(0, 0, 0, 0.14);
	}

	.skill-title-copy {
		min-width: 0;
		padding-top: 0.12rem;
	}

	.skill-title-copy h3 {
		color: rgba(15, 23, 42, 0.94);
		font-size: 1.18rem;
		font-weight: 900;
		line-height: 1.2;
		letter-spacing: -0.02em;
	}

	.dark .skill-title-copy h3 {
		color: rgba(255, 255, 255, 0.94);
	}

	.skill-title-copy p {
		margin-top: 0.38rem;
		color: rgba(71, 85, 105, 0.78);
		font-size: 0.9rem;
		line-height: 1.35;
	}

	.dark .skill-title-copy p {
		color: rgba(255, 255, 255, 0.58);
	}

	.skill-level-badge {
		flex: 0 0 auto;
		padding: 0.48rem 0.88rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--skill-color) 13%, white);
		color: var(--skill-color);
		font-size: 0.9rem;
		font-weight: 900;
		line-height: 1;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.85);
	}

	.dark .skill-level-badge {
		background: color-mix(in srgb, var(--skill-color) 22%, rgba(255, 255, 255, 0.05));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
	}

	.skill-description {
		display: -webkit-box;
		flex: 1 1 auto;
		margin-top: 1rem;
		color: rgba(51, 65, 85, 0.72);
		font-size: 0.98rem;
		line-height: 1.82;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
		overflow: hidden;
	}

	.dark .skill-description {
		color: rgba(255, 255, 255, 0.68);
	}

	.skill-description-bullet {
		display: inline-block;
		width: 0;
		height: 0;
		margin-right: 0.58rem;
		border-top: 0.24rem solid transparent;
		border-bottom: 0.24rem solid transparent;
		border-left: 0.35rem solid var(--skill-color);
		vertical-align: 0.08rem;
		opacity: 0.9;
	}

	.skill-progress-track {
		height: 0.58rem;
		margin-top: 1.1rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--skill-color) 10%, rgba(226, 232, 240, 0.9));
		overflow: hidden;
	}

	.dark .skill-progress-track {
		background: color-mix(in srgb, var(--skill-color) 16%, rgba(255, 255, 255, 0.08));
	}

	.skill-progress-fill {
		height: 100%;
		border-radius: inherit;
		background:
			linear-gradient(
				90deg,
				color-mix(in srgb, var(--skill-color) 82%, white),
				var(--skill-color)
			);
		box-shadow: 0 0 16px color-mix(in srgb, var(--skill-color) 28%, transparent);
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.skill-card:nth-child(1) {
		animation-delay: 0.03s;
	}
	.skill-card:nth-child(2) {
		animation-delay: 0.06s;
	}
	.skill-card:nth-child(3) {
		animation-delay: 0.09s;
	}
	.skill-card:nth-child(4) {
		animation-delay: 0.12s;
	}
	.skill-card:nth-child(5) {
		animation-delay: 0.15s;
	}
	.skill-card:nth-child(6) {
		animation-delay: 0.18s;
	}

	@media (max-width: 560px) {
		.skill-card {
			min-height: auto;
			border-radius: 1.25rem;
		}

		.skill-card-inner {
			padding: 1.1rem 1.05rem 1rem;
		}

		.skill-icon-box {
			width: 3.4rem;
			height: 3.4rem;
			border-radius: 1rem;
		}

		.skill-title-copy h3 {
			font-size: 1.05rem;
		}

		.skill-level-badge {
			padding: 0.42rem 0.74rem;
			font-size: 0.82rem;
		}

		.skill-description {
			font-size: 0.92rem;
			line-height: 1.72;
		}
	}
</style>
