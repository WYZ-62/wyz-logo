---
import { Icon } from "astro-icon/components";

import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import { formatDateToYYYYMMDD } from "../../../utils/date-utils";
import { getTagUrl } from "../../../utils/url-utils";
import { PublishedDate } from "./atoms";
import { Category } from "./atoms";
import { WordCount } from "./atoms";
import { ReadingTime } from "./atoms";
import { EncryptedBadge } from "./atoms";

interface Props {
	published: Date;
	updated?: Date;
	category?: string;
	tags?: string[];
	hideUpdateDate?: boolean;
	hideTagsForMobile?: boolean;
	isHome?: boolean;
	className?: string;
	pagePath?: string;
	showOnlyBasicMeta?: boolean;
	words?: number;
	minutes?: number;
	showWordCount?: boolean;
	showReadingTime?: boolean;
	showEncrypted?: boolean;
}

const {
	published,
	updated,
	category,
	tags,
	hideUpdateDate,
	hideTagsForMobile,
	isHome,
	className = "",
	pagePath,
	showOnlyBasicMeta = false,
	words,
	minutes,
	showWordCount = false,
	showReadingTime = false,
	showEncrypted = false,
} = Astro.props;
---

<div class:list={["flex flex-wrap text-neutral-500 dark:text-neutral-400 items-center gap-4 gap-x-4 gap-y-2", className]}>
    <PublishedDate date={published} />

    {!hideUpdateDate && updated && updated.getTime() !== published.getTime() && (
        <div class="flex items-center">
            <div class="meta-icon">
                <Icon name="material-symbols:edit-calendar-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium">{formatDateToYYYYMMDD(updated)}</span>
        </div>
    )}

    <Category category={category} />

    {showWordCount && words && (
        <WordCount words={words} />
    )}

    {showReadingTime && minutes && (
        <ReadingTime minutes={minutes} />
    )}

    {!showOnlyBasicMeta && (
        <div class:list={["items-center", {"flex": !hideTagsForMobile, "hidden md:flex": hideTagsForMobile}]}>
            <div class="meta-icon">
                <Icon name="material-symbols:tag-rounded" class="text-xl"></Icon>
            </div>
            <div class="flex flex-row flex-nowrap items-center">
                {(tags && tags.length > 0) && tags.map((tag, i) => (
                    <>
                        <div class:list={[{"hidden": i == 0}, "mx-1.5 text-[var(--meta-divider)] text-sm"]}>/</div>
                        <a href={getTagUrl(tag)} aria-label={`View all posts with the ${tag.trim()} tag`}
                           class="link-lg transition text-50 text-sm font-medium
                                        hover:text-[var(--primary)] dark:hover:text-[var(--primary)] whitespace-nowrap">
                            {tag.trim()}
                        </a>
                    </>
                ))}
                {!(tags && tags.length > 0) && <div class="transition text-50 text-sm font-medium">{i18n(I18nKey.noTags)}</div>}
            </div>
        </div>
    )}
    
    {!isHome && pagePath && (
        <div class="flex items-center umami-page-views hidden" data-path={pagePath}>
            <div class="meta-icon">
                <Icon name="material-symbols:visibility-outline-rounded" class="text-xl"></Icon>
            </div>
            <span class="text-50 text-sm font-medium page-views-display">{i18n(I18nKey.pageViewsLoading)}</span>
        </div>
    )}

    {showEncrypted && (
        <EncryptedBadge />
    )}
    
    {!isHome && pagePath && (
<script is:inline define:vars={{
    pageViewsText: i18n(I18nKey.profileStatsPageViews),
    visitsText: i18n(I18nKey.profileStatsVisits)
}}>
    (function () {
        if (window.__umamiPostMetaController?.cleanup) {
            window.__umamiPostMetaController.cleanup();
        }

        let retryTimer = null;
        const state = {
            pageviews: 0,
            visits: 0,
        };

        function normalizePath(pathname) {
            let normalized = pathname || "/";

            try {
                normalized = new URL(normalized, window.location.origin).pathname;
            } catch {}

            if (normalized !== "/") {
                normalized = `${normalized.replace(/\/+$/, "")}/`;
            }

            return normalized || "/";
        }

        function getContainer() {
            return document.querySelector(".umami-page-views");
        }

        function getPagePath() {
            return normalizePath(getContainer()?.dataset.path || "");
        }

        function generateStatsText(pageViews, visits) {
            return `${pageViewsText} ${pageViews} · ${visitsText} ${visits}`;
        }

        function renderStats() {
            const container = getContainer();
            if (!container) {
                return;
            }

            container.classList.remove("hidden");
            const display = container.querySelector(".page-views-display");
            if (display) {
                display.textContent = generateStatsText(
                    state.pageviews,
                    state.visits,
                );
            }
        }

        function scheduleRetry(options) {
            if (retryTimer) {
                window.clearTimeout(retryTimer);
            }

            retryTimer = window.setTimeout(function () {
                fetchPageViews(options);
            }, 600);
        }

        async function fetchPageViews(options) {
            const container = getContainer();
            if (!container) {
                return;
            }

            const path = getPagePath();
            if (!path) {
                return;
            }

            if (!window.oddmisc?.getStats) {
                scheduleRetry(options);
                return;
            }

            try {
                const stats = await window.oddmisc.getStats(path, options || {});
                state.pageviews = stats.pageviews || 0;
                state.visits = stats.visits || 0;
                renderStats();
            } catch (error) {
                console.error("Error fetching page views:", error);
                container.classList.add("hidden");
            }
        }

        function handleInitialLoad() {
            fetchPageViews();
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", handleInitialLoad);
        } else {
            handleInitialLoad();
        }

        window.addEventListener("oddmisc-ready", handleInitialLoad);
        document.addEventListener("astro:page-load", handleInitialLoad);

        window.__umamiPostMetaController = {
            cleanup() {
                if (retryTimer) {
                    window.clearTimeout(retryTimer);
                    retryTimer = null;
                }
                document.removeEventListener("DOMContentLoaded", handleInitialLoad);
                window.removeEventListener("oddmisc-ready", handleInitialLoad);
                document.removeEventListener("astro:page-load", handleInitialLoad);
            },
        };
    })();
</script>
)}
